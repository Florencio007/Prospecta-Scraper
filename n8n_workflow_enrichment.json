{
    "name": "Prospecta - Enrichissement Temps Réel (Hunter & Apollo.io)",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "prospect-enrich",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook-enrich",
            "name": "Webhook Enrich",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                100,
                300
            ]
        },
        {
            "parameters": {
                "url": "https://api.hunter.io/v2/domain-search",
                "options": {
                    "redirect": {
                        "redirect": {}
                    }
                },
                "queryParametersUi": {
                    "parameter": [
                        {
                            "name": "domain",
                            "value": "={{$json.body.website.replace('https://','').replace('http://','').split('/')[0]}}"
                        }
                    ]
                }
            },
            "id": "hunter-io",
            "name": "Hunter.io - Emails",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                400,
                150
            ],
            "credentials": {
                "httpHeaderAuth": {
                    "id": "YOUR_HUNTER_CRED_ID",
                    "name": "Hunter.io API Key"
                }
            },
            "continueOnFail": true
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://api.apollo.io/v1/organizations/enrich",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\n  \"domain\": \"{{$json.body.website.replace('https://','').replace('http://','').split('/')[0]}}\"\n}",
                "options": {}
            },
            "id": "apollo",
            "name": "Apollo.io - Business Info",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                400,
                450
            ],
            "credentials": {
                "httpHeaderAuth": {
                    "id": "YOUR_APOLLO_CRED_ID",
                    "name": "Apollo.io API Key"
                }
            },
            "continueOnFail": true
        },
        {
            "parameters": {
                "mode": "combine",
                "combineBy": "position",
                "options": {}
            },
            "id": "merge-results",
            "name": "Merge Results",
            "type": "n8n-nodes-base.merge",
            "typeVersion": 2.1,
            "position": [
                700,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "// Consolidation des données pour retour au frontend\nconst items = $input.all();\nconst hunter = items[0]?.json || {};\nconst apollo = items[1]?.json?.organization || {};\nconst original = $node[\"Webhook Enrich\"].json.body;\n\nlet score = original.score || 70;\nlet services = original.services || [];\nlet brandValues = original.brandValues || [];\n\n// 1. Emails Hunter\nconst verifiedEmail = hunter.data?.emails?.find(e => e.confidence > 80)?.value || hunter.data?.emails?.[0]?.value;\nif (verifiedEmail) score += 15;\n\n// 2. Apollo.io Info\nif (apollo.industry) services.push(apollo.industry);\nif (apollo.keywords) brandValues.push(...apollo.keywords.slice(0, 5));\nif (apollo.annual_revenue_estimated) score += 10;\n\nreturn {\n  json: {\n    id: original.id,\n    email: verifiedEmail || original.email,\n    score_global: Math.min(99, score),\n    services: [...new Set(services)],\n    brand_values: [...new Set(brandValues)],\n    tone_analysis: apollo.short_description || original.toneAnalysis || \"Profil enrichi avec succès via Apollo.io.\"\n  }\n};"
            },
            "id": "code-consolidation",
            "name": "Consolidate Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                950,
                300
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={{ { \"success\": true, \"data\": $json } }}"
            },
            "id": "respond-webhook",
            "name": "Respond to Webhook",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                1200,
                300
            ]
        }
    ],
    "connections": {
        "Webhook Enrich": {
            "main": [
                [
                    {
                        "node": "Hunter.io - Emails",
                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "Apollo.io - Business Info",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Hunter.io - Emails": {
            "main": [
                [
                    {
                        "node": "merge-results",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Apollo.io - Business Info": {
            "main": [
                [
                    {
                        "node": "merge-results",
                        "type": "main",
                        "index": 1
                    }
                ]
            ]
        },
        "merge-results": {
            "main": [
                [
                    {
                        "node": "code-consolidation",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "code-consolidation": {
            "main": [
                [
                    {
                        "node": "Respond to Webhook",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionOrder": "v1"
    },
    "tags": [
        {
            "name": "prospecta"
        },
        {
            "name": "enrichment"
        }
    ]
}